{
  "name": "PlayerEquipment",
  "type": "object",
  "properties": {
    "player_id": {
      "type": "string",
      "description": "Reference to player profile"
    },
    "items": {
      "type": "array",
      "description": "Equipment items the player owns or needs",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": [
              "footwear",
              "training_gear",
              "protection",
              "recovery",
              "technology",
              "nutrition",
              "other"
            ]
          },
          "owned": {
            "type": "boolean",
            "default": false
          },
          "condition": {
            "type": "string",
            "enum": [
              "new",
              "good",
              "worn",
              "needs_replacement",
              "not_applicable"
            ],
            "default": "not_applicable"
          },
          "usage_hours": {
            "type": "number",
            "default": 0,
            "description": "Estimated hours this item has been used"
          },
          "max_hours": {
            "type": "number",
            "description": "Recommended max hours before considering replacement"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "player_id"
  ]
}